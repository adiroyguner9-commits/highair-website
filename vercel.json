{
  "crons": [
    { "path": "/api/send-reminders", "schedule": "0 8 * * *" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/hero.mp4",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://*.userway.org https://link.msgsndr.com https://www.googletagmanager.com https://connect.facebook.net https://www.google-analytics.com https://googleads.g.doubleclick.net https://www.googleadservices.com; style-src 'self' 'unsafe-inline' https://*.userway.org; img-src 'self' data: blob: https://*.userway.org https://res.cloudinary.com https://*.airtableusercontent.com https://images.unsplash.com https://i.ytimg.com https://img.youtube.com https://www.facebook.com https://www.google-analytics.com https://www.googletagmanager.com; font-src 'self' https://*.userway.org; connect-src 'self' https://*.userway.org https://api.leadconnectorhq.com https://www.google-analytics.com https://stats.g.doubleclick.net https://www.facebook.com https://connect.facebook.net https://googleads.g.doubleclick.net https://pagead2.googlesyndication.com https://www.google.com; media-src 'self' https://res.cloudinary.com; frame-src 'self' https://*.userway.org https://www.youtube.com https://www.youtube-nocookie.com https://*.youtube.com https://api.leadconnectorhq.com https://bid.g.doubleclick.net; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none';"
        },
        { "key": "X-Content-Type-Options",  "value": "nosniff" },
        { "key": "X-Frame-Options",          "value": "DENY" },
        { "key": "Referrer-Policy",          "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",       "value": "camera=(), microphone=(), geolocation=(), payment=()" },
        { "key": "Strict-Transport-Security","value": "max-age=63072000; includeSubDomains; preload" }
      ]
    }
  ],
  "redirects": [
    { "source": "/kilimanjaro",        "destination": "/expedition/kilimanjaro",        "permanent": true },
    { "source": "/kilimanjaro-kosher", "destination": "/expedition/kilimanjaro-kosher", "permanent": true },
    { "source": "/elbrus",             "destination": "/expedition/elbrus",             "permanent": true },
    { "source": "/kazbek",             "destination": "/expedition/kazbek",             "permanent": true },
    { "source": "/aconcagua",          "destination": "/expedition/aconcagua",          "permanent": true },
    { "source": "/annapurna",          "destination": "/expedition/annapurna",          "permanent": true },
    { "source": "/manaslu",            "destination": "/expedition/manaslu",            "permanent": true },
    { "source": "/everest-base-camp",  "destination": "/expedition/everest-base-camp",  "permanent": true },
    { "source": "/olympus",            "destination": "/expedition/olympus",            "permanent": true },
    { "source": "/ethiopia",           "destination": "/expedition/ethiopia",           "permanent": true },
    { "source": "/peaks-of-balkan",    "destination": "/expedition/peaks-of-balkan",   "permanent": true },
    { "source": "/lobuche-peak",       "destination": "/expedition/lobuche-peak",      "permanent": true },
    { "source": "/island-peak",        "destination": "/expedition/island-peak",       "permanent": true },
    { "source": "/mera-peak",          "destination": "/expedition/mera-peak",         "permanent": true },
    { "source": "/lenin-peak",         "destination": "/expedition/lenin-peak",        "permanent": true },
    { "source": "/hermon",             "destination": "/israel/hermon",                "permanent": true },
    { "source": "/about-us",           "destination": "/about",                        "permanent": true },
    { "source": "/contact-us",         "destination": "/contact",                      "permanent": true },
